{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Artemis",
  "version": "0.1.0",
  "identifier": "com.artemis.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Artemis",
        "label": "main",
        "width": 1200,
        "height": 800
      },
      {
        "label": "ask",
        "title": "Ask Artemis",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "visible": false,
        "width": 640,
        "height": 420,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; frame-src 'none'"
    }
  }
}
