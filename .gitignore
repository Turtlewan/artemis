# --- Local / machine-specific ---
.claude/settings.local.json

# Research scratch + vendored external repos studied for prior-art (not part of the project)
.research/

# --- Secrets (backstop; specs keep these out by design — never commit) ---
.env
.env.*
!.env.*.example
*.key
*.pem
id_rsa*
*.wrapped
secrets/
keys/

# --- Encrypted / runtime data stores ---
*.db
*.sqlite
*.sqlite3
# Runtime data root (lives on the Mini, never in the repo)
/opt/artemis/
# Dev-box runtime root is the repo root (ARTEMIS_DATA_DIR=.): forge + auth + layout artifacts
.forge-test/
# capabilities/ is runtime storage for model-built capabilities (ignored), EXCEPT builtin/ —
# spec-built, repo-tracked infrastructure fetchers (ADR-046) that travel with the repo to the Mini.
/capabilities/*
!/capabilities/builtin/
/devices.json
/devices.json.lock
secrets_index.json
# Stray runtime artifacts from a brain instance run with cwd=client/ (see session-8 findings)
/client/capabilities/
/client/devices.json
/client/devices.json.lock
/client/docs/
/layout.json

# --- Python (forward-looking — code is built on the Mini) ---
__pycache__/
*.pyc
*.egg-info/
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- MLX model weights (large; not source) ---
models/
*.safetensors
*.gguf

# NOTE: datasets/distill/ is intentionally TRACKED (distill-datagen-pipeline §P3) — do not ignore.

# --- OS cruft ---
.DS_Store
Thumbs.db

# --- sandbox / test cache cruft (Codex restricted-token sandbox writes these) ---
.tmp/
.cache/
.pytest-tmp/
.scratch/
.sandbox/

# --- Codex build run logs + local build-progress notes (transient apex-code dispatch streams; not project docs) ---
docs/progress/

# Playwright MCP scratch output
.playwright-mcp/
